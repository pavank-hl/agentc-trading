# Core runtime
TAAPI_SECRET=
LEVERAGE_PCT=100
ORDERLY_ACCOUNT_ID=

# Volt monitoring + prompt sync
# The trading runtime uses these to:
# 1. fetch the active prompt version from volt-minions
# 2. ingest every analysis/decision event into Mongo via the API
VOLT_API_URL=http://localhost:3000
BOT_MONITORING_API_KEY=

# Optional fallback prompt version id used only if no active prompt exists
# in the Volt API yet.
PROMPT_VERSION_ID=

# Agent identity in monitoring events
USER_ID=
AGENT_NAME=unknown
